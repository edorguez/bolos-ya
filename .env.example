# Backend Configuration
# Copy this file to .env and update values

# Server
PORT=8080
SERVER_HOST=0.0.0.0
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bolosya_dev?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
JWT_ISSUER=bolos-ya

# Google OAuth (for mobile app authentication)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# AWS S3 (for premium user image storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET_NAME=bolos-ya-images
AWS_S3_ENDPOINT= # Leave empty for AWS, set for MinIO: http://localhost:9000

# BCV API (Banco Central de Venezuela exchange rate)
BCV_API_URL=https://www.bcv.org.ve
BCV_API_TIMEOUT=10s

# Application Settings
APP_ENV=development
APP_DEBUG=true
APP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Email (optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@bolosya.com

# Feature Flags
FEATURE_OCR_ENABLED=true
FEATURE_PREMIUM_ENABLED=false
FEATURE_PRICE_CONFIDENCE_ENABLED=true