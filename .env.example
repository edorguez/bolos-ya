# Backend Configuration for Local Development
# For Docker Compose, use .env.docker file with service names (postgres, redis, minio) instead of localhost

# Server
PORT=
SERVER_HOST=
SERVER_READ_TIMEOUT=
SERVER_WRITE_TIMEOUT=

# Database (PostgreSQL)
DATABASE_NAME=
DATABASE_PORT=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_URL=

# Redis
REDIS_PORT=
REDIS_DB=
REDIS_PASSWORD=
REDIS_URL=

# Auth Server (standalone better-auth service)
BETTER_AUTH_SECRET=
INTERNAL_API_KEY=
BETTER_AUTH_URL=

# Google OAuth (for better-auth social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS S3 (for premium user image storage)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_S3_ENDPOINT=

# BCV API (Banco Central de Venezuela exchange rate)
BCV_API_URL=

# MinIO 
MINIO_USER=
MINIO_PASSWORD=
MINIO_PORT_1=
MINIO_PORT_2=

# Application Settings
APP_ENV=
APP_DEBUG=
APP_ALLOWED_ORIGINS=
