{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "generate-api": "openapi-typescript-codegen --input ../docs/openapi.yaml --output ../gen/typescript --client axios && cp -r ../gen/typescript/* src/api/"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-navigation/native": "^7.2.0",
    "axios": "^1.13.6",
    "expo": "~55.0.8",
    "expo-camera": "^55.0.10",
    "expo-constants": "^55.0.9",
    "expo-file-system": "^55.0.11",
    "expo-image": "^55.0.6",
    "expo-linking": "^55.0.8",
    "expo-router": "^55.0.7",
    "expo-splash-screen": "^55.0.12",
    "expo-sqlite": "^55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "^55.0.10",
    "form-data": "^4.0.5",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-unistyles": "^3.1.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "openapi-typescript-codegen": "^0.30.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
