{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "generate-api": "npx openapi-typescript-codegen --input ../docs/openapi.yaml --output ../gen/typescript --client axios && cp -r ../gen/typescript/* api/"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@infinitered/react-native-mlkit-text-recognition": "^5.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.2.0",
    "axios": "^1.13.6",
    "expo": "~55.0.13",
    "expo-camera": "~55.0.11",
    "expo-constants": "~55.0.13",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.6",
    "expo-image": "~55.0.8",
    "expo-linking": "~55.0.12",
    "expo-router": "~55.0.11",
    "expo-splash-screen": "~55.0.17",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.15",
    "form-data": "^4.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "^0.83.4",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-unistyles": "^3.1.1",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@expo/webpack-config": "^19.0.1",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "babel-preset-expo": "^55.0.12",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "expo-build-properties": "^55.0.13",
    "openapi-typescript-codegen": "^0.30.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "webpack-cli": "^7.0.2"
  },
  "overrides": {
    "@expo/webpack-config": {
      "expo": "$expo"
    }
  },
  "private": true
}
