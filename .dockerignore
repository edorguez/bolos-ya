# Docker ignore file

# Git
.git
.gitignore

# Binaries and build artifacts
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test

# Coverage
coverage.*
*.out
*.coverprofile
profile.cov

# Go workspace
go.work
go.work.sum

# Environment files (except .env.example)
.env
.env.local
.env.*.local

# Editor/IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/

# Node.js (if any)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker files (self)
Dockerfile*
docker-compose*
.dockerignore

# Documentation
docs/_build/
*.pyc

# Temporary files
tmp/
temp/

# Local development files
.devcontainer/
.venv/
venv/

# Mobile app directories (if not needed)
mobile/
ios/
android/

# Test data
testdata/