<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pago rechazado - Bolos Ya</title>
</head>
<body style="margin:0;padding:0;background-color:#fbfaf9;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#fbfaf9;">
    <tr>
      <td align="center" style="padding:40px 0;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:10px;overflow:hidden;border:1px solid #f2f0ed;">
          <!-- Header -->
          <tr>
            <td style="background-color:#121212;padding:32px;text-align:center;">
              <h1 style="margin:0;color:#ffffff;font-size:23px;font-weight:600;letter-spacing:-0.44px;">BOLOS YA</h1>
            </td>
          </tr>
          <!-- Body -->
          <tr>
            <td style="padding:32px;text-align:center;">
              <!-- Red X circle -->
              <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto 24px auto;">
                <tr>
                  <td style="background-color:#ff2b3a;border-radius:50%;width:64px;height:64px;text-align:center;vertical-align:middle;">
                    <img src="data:image/svg+xml;base64," width="32" height="32" alt="✕" style="display:block;margin:16px auto;">
                  </td>
                </tr>
              </table>

              <h2 style="margin:0 0 8px 0;color:#121212;font-size:19px;font-weight:600;letter-spacing:-0.25px;">Lo sentimos, {{.Name}}</h2>
              <p style="margin:0 0 16px 0;color:#474645;font-size:15px;line-height:1.47;letter-spacing:-0.2px;">
                No pudimos procesar tu pago por el siguiente motivo:
              </p>

              <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto 24px auto;width:100%;">
                <tr>
                  <td style="background-color:#fef2f2;border-radius:10px;padding:16px 24px;text-align:center;border:1px solid #fee2e2;">
                    <p style="margin:0;color:#ff2b3a;font-size:15px;font-weight:600;line-height:1.47;letter-spacing:-0.2px;">{{.Reason}}</p>
                  </td>
                </tr>
              </table>

              {{if .CustomMessage}}
              <p style="margin:0 0 24px 0;color:#474645;font-size:15px;line-height:1.47;letter-spacing:-0.2px;">
                {{.CustomMessage}}
              </p>
              {{end}}

              <hr style="border:none;border-top:1px solid #f2f0ed;margin:24px 0;">

              <p style="margin:0 0 4px 0;color:#848281;font-size:12px;line-height:1.58;letter-spacing:-0.14px;">
                Si tienes dudas, contáctanos:
              </p>
              <p style="margin:0;color:#474645;font-size:14px;line-height:1.5;letter-spacing:-0.18px;">
                Correo: {{.SupportEmail}}<br>
                Teléfono: {{.SupportPhone}}
              </p>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="background-color:#f8f7f4;padding:24px;text-align:center;">
              <p style="margin:0;color:#848281;font-size:12px;line-height:1.58;letter-spacing:-0.14px;">
                &copy; 2026 Bolos Ya. Todos los derechos reservados.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
